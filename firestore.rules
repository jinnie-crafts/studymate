rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------
    // 🔧 HELPER FUNCTIONS
    // -------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // -------------------------
    // 👤 USERS COLLECTION
    // -------------------------

    match /users/{userId} {

      // Create own profile
      allow create: if isOwner(userId);

      // Read: only self OR admin
      allow read: if isOwner(userId) || isAdmin();

      // Update: only self
      allow update: if isOwner(userId);

      // Delete: disabled
      allow delete: if false;

      // -------------------------
      // 📱 SESSIONS SUBCOLLECTION
      // -------------------------
      match /sessions/{sessionId} {
        // Read: Realtime-safe read (avoids request.resource validation)
        allow read: if isOwner(userId);
        
        // Create: Strict schema and type validation
        allow create: if isOwner(userId)
          && request.resource.data.keys().hasAll(['sessionId', 'createdAt', 'lastSeenAt'])
          && request.resource.data.sessionId == sessionId
          && request.resource.data.sessionId is string
          && request.resource.data.createdAt is timestamp;
          
        // Update: Safe partial updates (heartbeat and revocation)
        allow update: if isOwner(userId)
          // 1. Immutable foundational fields
          && request.resource.data.sessionId == resource.data.sessionId
          && request.resource.data.createdAt == resource.data.createdAt
          // 2. Strict Affected-Key Limiting
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeenAt', 'revokedAt'])
          // 3. One-way revocation latch (once revoked, cannot un-revoke)
          && (
            !('revokedAt' in resource.data) 
            || resource.data.revokedAt == null 
            || request.resource.data.revokedAt == resource.data.revokedAt
          );
          
        // Delete: Soft delete only (via revokedAt)
        allow delete: if false;
      }
      // -------------------------
      // 🧠 MEMORY SUBCOLLECTION
      // -------------------------
      match /memory/{memoryId} {
        // Read: only owner
        allow read: if isOwner(userId);
        
        // Write: only owner with strict schema validation
        allow write: if isOwner(userId)
          && request.resource.data.keys().hasAll(['fact', 'category', 'confidence', 'timestamp'])
          && request.resource.data.keys().hasOnly(['fact', 'category', 'confidence', 'timestamp'])
          && request.resource.data.fact is string
          && request.resource.data.category is string
          && (request.resource.data.confidence is number || request.resource.data.confidence is string)
          && (request.resource.data.timestamp is number || request.resource.data.timestamp is timestamp);
      }
    }

    // -------------------------
    // 💬 CHATS COLLECTION
    // -------------------------

    match /chats/{chatId} {

      // Create chat — allow all fields the app writes
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'userId', 'title', 'mode', 'hinglish', 'notesMode', 'createdAt', 'updatedAt'
        ]);

      // Read/delete only by owner
      allow read, delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
        
      // Update by owner, preventing ownership transfer
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;

      // -------------------------
      // 💬 MESSAGES SUBCOLLECTION
      // -------------------------

      match /messages/{messageId} {

        allow create: if isAuthenticated()
          && request.auth.uid ==
            get(/databases/$(database)/documents/chats/$(chatId)).data.userId
          && request.resource.data.role in ["user", "ai"]
          && request.resource.data.content is string
          && request.resource.data.keys().hasOnly([
            'role', 'content', 'sources', 'intent', 'doubt', 'rag_enhanced', 'createdAt'
          ])
          && (!('intent' in request.resource.data) || request.resource.data.intent is string)
          // Support both bool and string for doubt to prevent regressions as AI payload formats evolve
          && (!('doubt' in request.resource.data) || request.resource.data.doubt is bool || request.resource.data.doubt is string)
          && (!('rag_enhanced' in request.resource.data) || request.resource.data.rag_enhanced is bool);

        allow read: if isAuthenticated()
          && request.auth.uid ==
            get(/databases/$(database)/documents/chats/$(chatId)).data.userId;

        // Prevent edits/deletes for integrity
        allow update, delete: if false;
      }
    }

    // -------------------------
    // 🔔 NOTIFICATIONS COLLECTION
    // -------------------------

    match /notifications/{notificationId} {

      // READ: Only recipient
      allow read: if isOwner(resource.data.userId);

      // CREATE: Only admin (Cloud Function / Admin SDK)
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'userId', 'title', 'message', 'type', 'isRead', 'createdAt'
        ])
        && request.resource.data.userId is string
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.type in ["info", "success", "warning"]
        && request.resource.data.isRead == false;

      // UPDATE: Only allow marking as read
      allow update: if isOwner(resource.data.userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);

      // DELETE: Disabled
      allow delete: if false;
    }

    // -------------------------
    // 📝 CHANGELOGS COLLECTION
    // -------------------------

    match /changelogs/{changelogId} {
      
      // READ: Publicly allowed (so the app can fetch the feed)
      allow read: if true;

      // CREATE / UPDATE / DELETE: Only admin
      allow create, update, delete: if isAdmin();
    }

    // -------------------------
    // 🚫 DEFAULT DENY
    // -------------------------

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
